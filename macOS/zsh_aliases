
# GNU tools take precedence over macOS BSD versions
for _pkg in coreutils findutils gnu-sed gnu-tar grep gawk gnu-indent gnu-which make gnu-time; do
    _gnubin="$(brew --prefix)/opt/${_pkg}/libexec/gnubin"
    [ -d "$_gnubin" ] && PATH="${_gnubin}:${PATH}"
done
_gnu_getopt="$(brew --prefix)/opt/gnu-getopt/bin"
[ -d "$_gnu_getopt" ] && PATH="${_gnu_getopt}:${PATH}"
export PATH
unset _pkg _gnubin _gnu_getopt

