# Qwen3.6-27B-MTP — local LLM via llama.cpp (Apple Silicon, 16GB RAM)
# Quant: UD-IQ3_XXS (~12.2 GB), MTP speculative decoding (~140 tok/s), Metal GPU
# --spec-type draft-mtp requires llama.cpp >= b9180 (May 2026+)
_QWEN27B_MODEL_DIR="${0:A:h:h}/models/unsloth/Qwen3.6-27B-MTP-GGUF"
_QWEN27B_ALIAS="unsloth/Qwen3.6-27B-MTP-GGUF"

# Interactive chat with Qwen3.6-27B model in terminal (loads model directly, no server needed)
# Usage: qwen27b-llama-chat "what is the capital of france?"
qwen27b-llama-chat() {
    local model_file
    model_file=$(find "$_QWEN27B_MODEL_DIR" -name "*UD-IQ3_XXS*.gguf" | sort | head -1)
    if [ -z "$model_file" ]; then
        echo "Model not found in $_QWEN27B_MODEL_DIR — run: bash macOS/download-qwen27b.sh"
        return 1
    fi
    local -a prompt_args=()
    [[ $# -gt 0 ]] && prompt_args=(-p "$*")
    llama-cli \
        --model "$model_file" \
        -ngl 99 \
        -c 8192 \
        -fa on \
        --spec-type draft-mtp \
        --spec-draft-n-max 1 \
        --temp 0.6 --top-k 20 --top-p 0.95 \
        -cnv "${prompt_args[@]}"
}

# Chat via OpenCode using the local llama-server (qwen27b-llama-server must be running)
# Usage: qwen27b-opencode
qwen27b-opencode() {
    command opencode --model "llama-local/qwen3.6-27b-mtp" "$@"
}

# Run Qwen3.6-27B as OpenAI-compatible API server for IDE integrations
# Usage: qwen27b-llama-server
#        Then connect OpenCode/Claude Code to http://localhost:8080/v1
qwen27b-llama-server() {
    local model_file
    model_file=$(find "$_QWEN27B_MODEL_DIR" -name "*UD-IQ3_XXS*.gguf" | sort | head -1)
    if [ -z "$model_file" ]; then
        echo "Model not found in $_QWEN27B_MODEL_DIR — run: bash macOS/download-qwen27b.sh"
        return 1
    fi
    echo "Loading: $model_file"
    # --jinja required for tool calling (opencode and Claude Code)
    llama-server \
        --model "$model_file" \
        --alias "$_QWEN27B_ALIAS" \
        -ngl 99 \
        -fa on \
        -c 16384 \
        --jinja \
        --spec-type draft-mtp \
        --spec-draft-n-max 2 \
        -np 1 "$@"
}

# Use Claude Code with local qwen27b-llama-server without editing ~/.claude/settings.json
# Usage: qwen27b-claude [args]
qwen27b-claude() {
    ANTHROPIC_BASE_URL="http://localhost:8080/v1" \
    ANTHROPIC_API_KEY="sk-local" \
    CLAUDE_CODE_ATTRIBUTION_HEADER="0" \
    CLAUDE_CODE_ENABLE_TELEMETRY="0" \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="1" \
    command claude --model "$_QWEN27B_ALIAS" "$@"
}

# Machine hardware info + current resource snapshot
machine-info() {
    echo "── Hardware ─────────────────────────────────"
    system_profiler SPHardwareDataType | grep -E "Chip|Memory:|Cores" | sed 's/^[[:space:]]*/  /'
    sw_vers | grep -E "ProductName|ProductVersion" | sed 's/^[[:space:]]*/  /'

    echo ""
    echo "── Memory ───────────────────────────────────"
    vm_stat | awk '
        /Pages free:/                   { free=$3+0 }
        /Pages active:/                 { act=$3+0 }
        /Pages inactive:/               { inact=$3+0 }
        /Pages wired down:/             { wire=$4+0 }
        /Pages occupied by compressor:/ { comp=$5+0 }
        END {
            p = 16384 / 1073741824
            printf "  Free:       %5.1f GB\n",  free*p
            printf "  Active:     %5.1f GB\n",  act*p
            printf "  Inactive:   %5.1f GB  (reclaimable)\n", inact*p
            printf "  Wired:      %5.1f GB\n",  wire*p
            printf "  Compressed: %5.1f GB\n",  comp*p
        }'

    echo ""
    echo "── CPU ──────────────────────────────────────"
    uptime | awk -F'load averages:' '{print "  Load avg:" $2}'
    sysctl -n hw.logicalcpu | awk '{print "  Cores:    " $1}'

    echo ""
    echo "── GPU (Apple Silicon) ──────────────────────"
    local gpu
    gpu=$(ioreg -r -d 1 -w 0 -c AGXAccelerator 2>/dev/null | grep -o '"PerformanceStatistics" = {[^}]*}')
    GPU_STATS="$gpu" python3 - <<'PYEOF'
import os, re
s = os.environ['GPU_STATS']
def g(k):
    m = re.search('"' + k + r'"=(\d+)', s)
    return int(m.group(1)) if m else 0
alloc = g('Alloc system memory') / 1073741824
inuse = g('In use system memory') / 1073741824
print(f'  Utilization: {g("Device Utilization %")}%  (renderer {g("Renderer Utilization %")}%  tiler {g("Tiler Utilization %")}%)')
print(f'  Memory:      {inuse:.2f} GB in use / {alloc:.2f} GB allocated')
PYEOF

    echo ""
    echo "── Disk ─────────────────────────────────────"
    df -h / | awk 'NR>1 {printf "  /   %s used of %s (%s)\n", $3, $2, $5}'

    echo ""
    echo "── Battery ──────────────────────────────────"
    pmset -g batt | grep InternalBattery | sed 's/^[[:space:]]*/  /'
}

# Top processes by CPU, memory, network, and GPU usage
top-procs() {
    echo "── Top CPU ──────────────────────────────────"
    ps aux -r | awk '
        NR==1 { printf "  %-6s %5s %5s  %s\n","PID","%CPU","%MEM","COMMAND" }
        NR>1 && NR<=9 { n=split($11,a,"/"); printf "  %-6s %5s %5s  %s\n",$2,$3,$4,a[n] }'

    echo ""
    echo "── Top Memory ───────────────────────────────"
    ps aux -m | awk '
        NR==1 { printf "  %-6s %5s %5s  %s\n","PID","%CPU","%MEM","COMMAND" }
        NR>1 && NR<=9 { n=split($11,a,"/"); printf "  %-6s %5s %5s  %s\n",$2,$3,$4,a[n] }'

    echo ""
    echo "── Network (established connections) ────────"
    lsof -i -n -P 2>/dev/null | awk '
        /ESTABLISHED/ { n=split($1,a,"/"); printf "  %-22s %s\n", a[n], $9 }' \
        | sort -u | head -12

    echo ""
    echo "── GPU (Apple Silicon) ──────────────────────"
    local gpu
    gpu=$(ioreg -r -d 1 -w 0 -c AGXAccelerator 2>/dev/null | grep -o '"PerformanceStatistics" = {[^}]*}')
    GPU_STATS="$gpu" python3 - <<'PYEOF'
import os, re
s = os.environ['GPU_STATS']
def g(k):
    m = re.search('"' + k + r'"=(\d+)', s)
    return int(m.group(1)) if m else 0
alloc = g('Alloc system memory') / 1073741824
inuse = g('In use system memory') / 1073741824
print(f'  Device:    {g("Device Utilization %")}%')
print(f'  Renderer:  {g("Renderer Utilization %")}%')
print(f'  Tiler:     {g("Tiler Utilization %")}%')
print(f'  Memory:    {inuse:.2f} GB in use / {alloc:.2f} GB allocated')
print('  (per-process GPU: sudo powermetrics -n 1 --samplers gpu_power)')
PYEOF
}
