# GNU Screen configuration file
# https://www.gnu.org/software/screen/

# Disable startup message
startup_message off

# Use current shell (zsh)
shell -$SHELL
shelltitle "$ |zsh"

# Enable 256 color support
term screen-256color

# Enable mouse scrolling and hardstatus support
termcapinfo xterm* ti@:te@
termcapinfo xterm* hs:ts=\E]0;:fs=\007:ds=\E]0;\007

# Set scrollback buffer
defscrollback 10000

# Set default encoding to UTF-8
defutf8 on

# Enable alternate screen
altscreen on

# Auto-detach on hangup
autodetach on

# Don't open windows as login shells (avoids /etc/motd spam)
deflogin off

# Prevent one frozen window from blocking others
nonblock on

# Hardstatus: hostname | session name | date time
hardstatus alwayslastline
hardstatus string '%{= kw}[ %{= kG}%H%{= kw} ][ %{= kg}%S%{= kw} ]%=%{= kB} %Y-%m-%d %{= kW}%0c '

# Caption: window list per region (active window highlighted)
caption always '%{= kw}%?%-Lw%?%{= BW} %n %t %{-}%?%+Lw%?'

# Enable activity monitoring
activity "Activity in window %n"

# Window numbering starts at 1 (not 0)
bind c screen 1
bind 0 select 10

# Prevent accidental lock
bind ^x
bind x

# Navigation shortcuts
bind j focus down
bind k focus up
bind Tab focus

# Split screen bindings
bind s split
bind v split -v
bind r remove
bind o only

# Interactive window list
bind W windowlist -b

# Reload configuration
bind R source ~/.screenrc
